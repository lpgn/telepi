TELEGRAM_BOT_TOKEN=123456789:replace_me

# Required: your Telegram numeric user ID
OWNER_TELEGRAM_USER_ID=123456789

# Optional: lock the bot to one private chat ID after you confirm it
# OWNER_CHAT_ID=123456789

# true = reject groups/supergroups/channels
ALLOW_PRIVATE_CHATS_ONLY=true

# Unlock mode: totp or secret
UNLOCK_METHOD=totp

# If using TOTP, put a base32 secret here and add it to your authenticator app
UNLOCK_TOTP_SECRET=JBSWY3DPEHPK3PXP

# If using shared secret instead of TOTP:
# UNLOCK_METHOD=secret
# UNLOCK_SHARED_SECRET=replace_with_long_random_secret

# Minutes before the bot auto-locks again
UNLOCK_TTL_MINUTES=15

# Alert the owner in Telegram on denied attempts
ALERT_OWNER_ON_DENIED=true

# Audit log path
AUDIT_LOG_FILE=/path/to/telepi/logs/audit.log

# Optional: persisted unlock state file so unlock survives service restarts
# UNLOCK_STATE_FILE=/path/to/telepi/data/unlock-state.json

# Optional message size cap
MAX_TEXT_LENGTH=12000

# Choose where pi should operate. Narrow this if you can.
PI_WORKSPACE_DIR=/path/to/workspace
PI_AGENT_DIR=~/.pi/agent

# Optional: pin a specific pi model instead of using pi's defaults/settings
# PI_MODEL_PROVIDER=anthropic
# PI_MODEL_NAME=claude-sonnet-4-20250514

# Optional: off | low | medium | high
PI_THINKING_LEVEL=medium
